{
  "openapi": "3.1.0",
  "info": {
    "title": "CENEMS Cloud Bridge",
    "description": "Service for uploading IoT device readings with schema validation",
    "version": "1.0.0"
  },
  "paths": {
    "/": {
      "get": {
        "summary": "Root",
        "operationId": "root__get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "Health Check",
        "operationId": "health_check_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/health/nats": {
      "get": {
        "summary": "Nats Health Check",
        "description": "Get detailed NATS health status.",
        "operationId": "nats_health_check_health_nats_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/upload/reading": {
      "post": {
        "summary": "Upload Device Reading",
        "description": "Upload a single device reading\n\n- Validates JSON schema\n- Maps serialNumber to device/site/org IDs\n- Stores entire payload as reading data",
        "operationId": "upload_device_reading_upload_reading_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DeviceDataUpload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataUploadResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/upload/readings/bulk": {
      "post": {
        "summary": "Upload Bulk Readings",
        "description": "Upload multiple device readings in bulk with partial success support",
        "operationId": "upload_bulk_readings_upload_readings_bulk_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BulkDataUpload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BulkUploadResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/device/{serial_number}/info": {
      "get": {
        "summary": "Get Device Info",
        "description": "Get device information by serial number",
        "operationId": "get_device_info_device__serial_number__info_get",
        "parameters": [
          {
            "name": "serial_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Serial Number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/schema/device-data": {
      "get": {
        "summary": "Get Device Data Schema",
        "description": "Get the JSON schema for device data validation",
        "operationId": "get_device_data_schema_schema_device_data_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BulkDataUpload": {
        "properties": {
          "readings": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array",
            "title": "Readings",
            "description": "List of device readings to upload"
          }
        },
        "type": "object",
        "required": [
          "readings"
        ],
        "title": "BulkDataUpload",
        "description": "Schema for bulk uploading multiple readings"
      },
      "BulkUploadResponse": {
        "properties": {
          "summary": {
            "$ref": "#/components/schemas/BulkUploadSummary"
          },
          "results": {
            "items": {
              "$ref": "#/components/schemas/DataUploadResponse"
            },
            "type": "array",
            "title": "Results"
          }
        },
        "type": "object",
        "required": [
          "summary",
          "results"
        ],
        "title": "BulkUploadResponse"
      },
      "BulkUploadSummary": {
        "properties": {
          "total": {
            "type": "integer",
            "title": "Total"
          },
          "successful": {
            "type": "integer",
            "title": "Successful"
          },
          "failed": {
            "type": "integer",
            "title": "Failed"
          }
        },
        "type": "object",
        "required": [
          "total",
          "successful",
          "failed"
        ],
        "title": "BulkUploadSummary"
      },
      "DataUploadResponse": {
        "properties": {
          "success": {
            "type": "boolean",
            "title": "Success",
            "description": "Whether the upload was successful"
          },
          "message": {
            "type": "string",
            "title": "Message",
            "description": "Success or error message"
          },
          "reading_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Reading Id",
            "description": "ID of created reading record"
          },
          "device_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Device Id",
            "description": "Device ID"
          },
          "site_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Site Id",
            "description": "Site ID"
          },
          "org_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Org Id",
            "description": "Organization ID"
          },
          "reading_index": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Reading Index",
            "description": "Index in bulk upload (if applicable)"
          },
          "original_data": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Original Data",
            "description": "Original data"
          }
        },
        "type": "object",
        "required": [
          "success",
          "message"
        ],
        "title": "DataUploadResponse",
        "description": "Response schema for data upload operations"
      },
      "DeviceDataUpload": {
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "title": "Timestamp",
            "description": "Timestamp of the reading"
          },
          "source_tag": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Source Tag",
            "description": "Optional source tag used for automated mapping profile selection"
          },
          "data": {
            "additionalProperties": true,
            "type": "object",
            "title": "Data",
            "description": "Device data payload (must include serialNumber)"
          }
        },
        "type": "object",
        "required": [
          "timestamp",
          "data"
        ],
        "title": "DeviceDataUpload",
        "description": "Schema for uploading device reading data"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}